# ============================================================
# QSMS Rework Management System - Environment Variables Template
# ============================================================
# คัดลอกไฟล์นี้เป็น .env แล้วกรอกค่าจริง
# ไฟล์นี้ (.env.example) สามารถ commit เข้า Git ได้
# ============================================================

# GAS Web App URL (server-side / Next.js API)
GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_GAS_DEPLOYMENT_ID/exec

# GAS Web App URL (client-side / React)
REACT_APP_GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_GAS_DEPLOYMENT_ID/exec

# GAS Web App URL (Vite builds)
VITE_GAS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_GAS_DEPLOYMENT_ID/exec

# GAS Calendar / Roster module URL
GAS_CALENDAR_WEB_APP_URL=https://script.google.com/macros/s/YOUR_CALENDAR_GAS_ID/exec

# Environment: development | production | test
NODE_ENV=development
REACT_APP_ENVIRONMENT=development

# Sentry DSN (optional)
REACT_APP_SENTRY_DSN=

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

