# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# ===== QSMS REWORK SYSTEM =====

# Development Mode: Use mock data for testing UI when GAS backend is not ready
VITE_USE_MOCK_DATA=false

# Google Apps Script Web App URL
# Get this from your GAS deployment: Deploy → Web App → copy URL
REACT_APP_GAS_WEB_APP_URL=https://script.google.com/macros/s/AKfycbzAJ4DSntkwXFRpGT0tSNlpDTxjAnkcfdC_KQGEN3GtKQDUOar0gm02j58ECasmi8nJ/exec
# ===== DEPRECATED: FIREBASE (NO LONGER USED) =====
# System now uses PIN-based authentication with session storage
# Firebase configuration is kept here for reference only

# Firebase Configuration (Get from https://console.firebase.google.com)
# DEPRECATED - System uses PIN auth instead
REACT_APP_FIREBASE_API_KEY=deprecated
REACT_APP_FIREBASE_AUTH_DOMAIN=deprecated
REACT_APP_FIREBASE_PROJECT_ID=deprecated
REACT_APP_FIREBASE_STORAGE_BUCKET=deprecated
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=deprecated
REACT_APP_FIREBASE_APP_ID=deprecated

# Google OAuth Configuration (Get from https://console.cloud.google.com)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ===== GOOGLE APPS SCRIPT & SHEETS =====
# GAS Web App URL (Deploy GAS as Web App and copy deployment URL)
REACT_APP_GAS_WEB_APP_URL=https://script.google.com/macros/s/AKfycbyvrhjJ05uJCGgAXiFM5IjEnv1vG6ps7Jk3x18kmsf1bWyua9Q4F3bbwaoAqPZgUybL/exec

# Google Sheet ID (Extract from spreadsheet URL)
REACT_APP_GOOGLE_SHEET_ID=1Zw66PocKhrTHpPj20Tt2DwBep1vHfbrWw9soX0afss0

# ===== OPTIONAL: ANALYTICS & ERROR TRACKING =====
REACT_APP_SENTRY_DSN=
REACT_APP_ANALYTICS_ID=

# ===== ENVIRONMENT =====
REACT_APP_ENVIRONMENT=development

# ===== FEATURE FLAGS =====
REACT_APP_ENABLE_MFA=false
REACT_APP_ENABLE_AUDIT_LOG=false
REACT_APP_ENABLE_DATA_EXPORT=true

# ===== AUTH SETTINGS =====
REACT_APP_TOKEN_EXPIRY_HOURS=8
REACT_APP_SESSION_TIMEOUT_MINUTES=480

# NOTE:
# Authentication credentials for user profiles are stored in Google Apps Script Properties.
# Configure the following script properties in the GAS editor:
#   AUTH_TOKEN_SECRET
#   QSMS_PIN
#   QSMS_EMAIL
#   QSMS_NAME
#   QSMS_ROLE
#   QSMS_DEPARTMENT
#   WFG_PIN
#   WFG_EMAIL
#   WFG_NAME
#   WFG_ROLE
#   WFG_DEPARTMENT
